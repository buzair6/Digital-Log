generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}
// Note: SQLite connector may not fully support enums/Json; use string fields for portability.

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  fullName          String?
  passwordHash      String
  role              String    @default("USER")
  // JSON fields stored as strings in SQLite (use JSONB in Postgres)
  customPermissions String?
  groupId           String? 
  group             Group?    @relation(fields: [groupId], references: [id])
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // relations
  createdTemplates  ChecklistTemplate[] @relation("templateCreatedBy")
  createdGroups     Group[] @relation("GroupCreatedBy")
  reviewedInstances  ChecklistInstance[] @relation("instanceReviewedBy")
  startedInstances  ChecklistInstance[] @relation("instanceStartedBy")
  assignedInstances ChecklistInstance[] @relation("instanceAssignedTo")
  filledResponses   ChecklistResponse[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  comments          ChecklistComment[]
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String @default("CUSTOM")
  createdById String? 
  createdBy   User?    @relation("GroupCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  // members: optional one-to-many relation via User.groupId
  members     User[]

  // default routing for templates
  templates   ChecklistTemplate[] @relation("templateRoutingGroup")
  routedInstances ChecklistInstance[] @relation("instanceRoutedTo")
}

model ChecklistTemplate {
  id                     String    @id @default(cuid())
  name                   String
  description            String?
  createdById            String
  createdBy              User      @relation("templateCreatedBy", fields: [createdById], references: [id])
  version                Int       @default(1)
  isActive               Boolean   @default(true)
  // routingRules stored as JSON string for SQLite (phase 2 supports complex rules)
  routingRules           String?
  defaultRoutingGroupId  String? 
  defaultRoutingGroup    Group?    @relation("templateRoutingGroup", fields: [defaultRoutingGroupId], references: [id])
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  nodes                  ChecklistNode[]
  instances              ChecklistInstance[]
}

model ChecklistNode {
  id           String       @id @default(cuid())
  templateId   String
  template     ChecklistTemplate @relation(fields: [templateId], references: [id])
  parentNodeId String? 
  parent       ChecklistNode? @relation("NodeChildren", fields: [parentNodeId], references: [id])
  children     ChecklistNode[] @relation("NodeChildren")
  orderIndex   Int          @default(0)
  title        String
  nodeType     String
  inputType    String?
  options      String?
  isRequired   Boolean      @default(false)
  helpText     String?
  depthLevel   Int?         
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  responses    ChecklistResponse[]
}

model ChecklistInstance {
  id                   String          @id @default(cuid())
  templateId           String
  template             ChecklistTemplate @relation(fields: [templateId], references: [id])
  status               String  @default("DRAFT")
  assignedToUserId     String? 
  assignedToUser       User?           @relation("instanceAssignedTo", fields: [assignedToUserId], references: [id])
  routedToGroupId      String? 
  routedToGroup        Group?          @relation("instanceRoutedTo", fields: [routedToGroupId], references: [id])
  createdById          String
  createdBy            User            @relation("instanceStartedBy", fields: [createdById], references: [id])
  startedAt            DateTime?
  submittedAt          DateTime?
  reviewedAt           DateTime?
  reviewedById         String?
  reviewedBy           User?           @relation("instanceReviewedBy", fields: [reviewedById], references: [id])
  reviewComments       String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  responses            ChecklistResponse[]
  comments             ChecklistComment[]

  @@index([status])
}

model ChecklistResponse {
  id             String    @id @default(cuid())
  instanceId     String
  instance       ChecklistInstance @relation(fields: [instanceId], references: [id])
  nodeId         String
  node           ChecklistNode @relation(fields: [nodeId], references: [id])
  value          String?
  fileUrl        String?
  filledByUserId String
  filledBy       User      @relation(fields: [filledByUserId], references: [id])
  filledAt       DateTime  @default(now())
  isComplete     Boolean   @default(false)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String?
  url       String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ChecklistComment {
  id         String   @id @default(cuid())
  instanceId String
  instance   ChecklistInstance @relation(fields: [instanceId], references: [id])
  nodeId     String?  // nullable: general comment vs node-specific
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  text       String
  createdAt  DateTime @default(now())
}

// End of schema

