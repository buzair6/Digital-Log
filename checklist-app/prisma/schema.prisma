generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}
// Note: SQLite connector may not fully support enums/Json; use string fields for portability.

model CorrectiveAction {
  id              String    @id @default(cuid())
  instanceId      String
  instance        ChecklistInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  nodeId          String?
  title           String
  description     String?
  priority        String    @default("MEDIUM")
  status          String    @default("OPEN")
  assignedToUserId String?
  assignedToUser  User?     @relation("ActionAssignee", fields: [assignedToUserId], references: [id])
  dueDate         DateTime?
  createdById     String
  createdBy       User      @relation("ActionCreatedBy", fields: [createdById], references: [id])
  completedAt     DateTime?
  evidenceUrl     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  fullName          String?
  passwordHash      String
  role              String    @default("USER")
  customPermissions String?
  groupId           String? 
  group             Group?    @relation(fields: [groupId], references: [id])
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdTemplates  ChecklistTemplate[] @relation("templateCreatedBy")
  createdGroups     Group[] @relation("GroupCreatedBy")
  reviewedInstances  ChecklistInstance[] @relation("instanceReviewedBy")
  startedInstances  ChecklistInstance[] @relation("instanceStartedBy")
  assignedInstances ChecklistInstance[] @relation("instanceAssignedTo")
  filledResponses   ChecklistResponse[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  comments          ChecklistComment[]
  todos             Todo[]
  addedGroupMembers GroupMember[] @relation("GroupMemberAddedBy")
  initiatedRoutes   ChecklistRoute[] @relation("RouteInitiatedBy")
  schedules         Schedule[] @relation("ScheduleCreatedBy")
  assignedActions   CorrectiveAction[] @relation("ActionAssignee")
  createdActions    CorrectiveAction[] @relation("ActionCreatedBy")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String @default("CUSTOM")
  createdById String? 
  createdBy   User?    @relation("GroupCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  members     User[]
  emailMembers GroupMember[]

  templates   ChecklistTemplate[] @relation("templateRoutingGroup")
  routedInstances ChecklistInstance[] @relation("instanceRoutedTo")
  routedHistory ChecklistRoute[]
}

model ChecklistTemplate {
  id                     String    @id @default(cuid())
  name                   String
  description            String?
  createdById            String
  createdBy              User      @relation("templateCreatedBy", fields: [createdById], references: [id])
  version                Int       @default(1)
  isActive               Boolean   @default(true)
  routingRules           String?
  defaultRoutingGroupId  String? 
  defaultRoutingGroup    Group?    @relation("templateRoutingGroup", fields: [defaultRoutingGroupId], references: [id])
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  nodes                  ChecklistNode[]
  instances              ChecklistInstance[]
  schedules              Schedule[] @relation("ScheduleTemplate")
}

model ChecklistNode {
  id           String       @id @default(cuid())
  templateId   String
  template     ChecklistTemplate @relation(fields: [templateId], references: [id])
  parentNodeId String? 
  parent       ChecklistNode? @relation("NodeChildren", fields: [parentNodeId], references: [id])
  children     ChecklistNode[] @relation("NodeChildren")
  orderIndex   Int          @default(0)
  title        String
  nodeType     String
  inputType    String?
  options      String?
  isRequired   Boolean      @default(false)
  helpText     String?
  depthLevel   Int?         

  minValue          String?
  maxValue          String?
  exceptionAction   String?

  weight            Float?
  scoreMap          String?
  visibleWhen       String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  responses    ChecklistResponse[]
}

model ChecklistInstance {
  id                   String          @id @default(cuid())
  templateId           String
  template             ChecklistTemplate @relation(fields: [templateId], references: [id])
  status               String  @default("DRAFT")
  assignedToUserId     String? 
  assignedToUser       User?           @relation("instanceAssignedTo", fields: [assignedToUserId], references: [id])
  routedToGroupId      String? 
  routedToGroup        Group?          @relation("instanceRoutedTo", fields: [routedToGroupId], references: [id])
  createdById          String
  createdBy            User            @relation("instanceStartedBy", fields: [createdById], references: [id])
  startedAt            DateTime?
  submittedAt          DateTime?
  reviewedAt           DateTime?
  reviewedById         String?
  reviewedBy           User?           @relation("instanceReviewedBy", fields: [reviewedById], references: [id])
  reviewComments       String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  assetId              String?
  asset                Asset?  @relation("InstanceAsset", fields: [assetId], references: [id])

  score            Float?
  maxScore         Float?
  passed           Boolean?
  flaggedCount     Int      @default(0)

  responses            ChecklistResponse[]
  comments             ChecklistComment[]
  routes               ChecklistRoute[]
  correctiveActions    CorrectiveAction[]

  @@index([status])
}

model ChecklistResponse {
  id             String    @id @default(cuid())
  instanceId     String
  instance       ChecklistInstance @relation(fields: [instanceId], references: [id])
  nodeId         String
  node           ChecklistNode @relation(fields: [nodeId], references: [id])
  value          String?
  fileUrl        String?
  fileName       String?
  capturedAt     DateTime?
  geoLat         Float?
  geoLng         Float?
  filledByUserId String
  filledBy       User      @relation(fields: [filledByUserId], references: [id])
  filledAt       DateTime  @default(now())
  isComplete     Boolean  @default(false)
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  addedById String?
  addedBy   User?    @relation("GroupMemberAddedBy", fields: [addedById], references: [id])
  createdAt DateTime @default(now())

  @@unique([groupId, email])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model ChecklistRoute {
  id          String   @id @default(cuid())
  instanceId  String
  instance    ChecklistInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])
  groupName   String?
  emailCount  Int      @default(0)
  signedToken String?
  status      String   @default("PENDING")
  routedById  String?
  routedBy    User?    @relation("RouteInitiatedBy", fields: [routedById], references: [id])
  routedAt    DateTime @default(now())
  completedAt DateTime?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String?
  url       String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ChecklistComment {
  id         String   @id @default(cuid())
  instanceId String
  instance   ChecklistInstance @relation(fields: [instanceId], references: [id])
  nodeId     String?
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  text       String
  createdAt  DateTime @default(now())
}

model Todo {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Schedule {
  id               String   @id @default(cuid())
  name             String
  templateId       String
  template         ChecklistTemplate @relation("ScheduleTemplate", fields: [templateId], references: [id])
  cronExpr         String?
  intervalMinutes  Int?
  lastRunAt        DateTime?
  nextRunAt        DateTime
  assignedToUserId String?
  routedToGroupId  String?
  isActive         Boolean  @default(true)
  createdById      String
  createdBy        User     @relation("ScheduleCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime @default(now())
}

model Asset {
  id        String   @id @default(cuid())
  tag       String   @unique
  name      String
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  instances ChecklistInstance[] @relation("InstanceAsset")
}